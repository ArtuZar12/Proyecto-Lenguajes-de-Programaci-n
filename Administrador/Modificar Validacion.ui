<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>Dialog</class>
 <widget class="QDialog" name="Dialog">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>400</width>
    <height>296</height>
   </rect>
  </property>
  <property name="windowTitle">
   <string>Dialog</string>
  </property>
  <property name="styleSheet">
   <string notr="true">/* =========================================
   1. FONDO DE LA VENTANA (DIALOG)
   ========================================= */
QDialog, #Dialog {
    background-color: #0a0a0a; /* Negro oscuro profundo */
}

/* =========================================
   2. TEXTOS (LABELS)
   ========================================= */
QLabel {
    color: #ffffff;
}

/* =========================================
   3. CAJAS DE TEXTO Y ENTRADAS
   ========================================= */
QLineEdit, QTextEdit, QPlainTextEdit, QSpinBox, QDoubleSpinBox {
    background-color: rgba(30, 30, 30, 200);
    border: 2px solid #555555;
    border-radius: 8px;
    color: #ffffff;
    padding: 8px;
    font-size: 13px;
}

QLineEdit:focus, QTextEdit:focus, QSpinBox:focus {
    border: 2px solid #ff0000;
    background-color: rgba(50, 20, 20, 200);
}

/* =========================================
   4. BOTONES (INCLUYE QDIALOGBUTTONBOX)
   ========================================= */
/* Esto afectará tanto a botones sueltos como a los de Aceptar/Cancelar */
QPushButton {
    background-color: #ff0000;
    color: white;
    border-radius: 8px;
    padding: 8px 15px;
    font-size: 14px;
    font-weight: bold;
    min-width: 80px; /* Asegura que los botones del Dialog no se vean muy pequeños */
}

QPushButton:hover {
    background-color: #cc0000;
}

QPushButton:pressed {
    background-color: #aa0000;
}

/* Estilo específico para los botones del ButtonBox si quieres que se vean distintos */
QDialogButtonBox QPushButton {
    margin-left: 5px;
}</string>
  </property>
  <layout class="QVBoxLayout" name="verticalLayout_2">
   <item>
    <layout class="QVBoxLayout" name="verticalLayout">
     <item>
      <widget class="QLineEdit" name="lineEdit">
       <property name="placeholderText">
        <string>Ingrese el Usuario a Modificar</string>
       </property>
      </widget>
     </item>
    </layout>
   </item>
   <item>
    <widget class="QDialogButtonBox" name="buttonBox">
     <property name="orientation">
      <enum>Qt::Horizontal</enum>
     </property>
     <property name="standardButtons">
      <set>QDialogButtonBox::Cancel|QDialogButtonBox::Ok</set>
     </property>
    </widget>
   </item>
  </layout>
 </widget>
