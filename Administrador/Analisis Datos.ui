      <item>
       <widget class="QScrollArea" name="scrollArea">
        <property name="styleSheet">
         <string notr="true">/* =========================================
   9. ESTILO PARA EL ÁREA DE DESPLAZAMIENTO
   ========================================= */
QScrollArea {
    border: none; /* Quitamos el borde para que no se vea una caja dentro de otra */
    background-color: transparent;
}

/* El fondo del contenido interno */
#scrollAreaWidgetContents {
    background-color: #0a0a0a; /* Mismo negro que el fondo principal */
}

/* Reutilizamos el estilo de la barra roja que hicimos antes */
QScrollBar:vertical {
    background-color: #0a0a0a;
    width: 12px;
    margin: 0px;
}

QScrollBar::handle:vertical {
    background-color: #ff0000; /* Rojo Neón */
    border-radius: 6px;
    min-height: 20px;
}</string>
        </property>
