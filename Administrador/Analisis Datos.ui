  <property name="styleSheet">
   <string notr="true">/* =========================================
   1. FONDO DE LA VENTANA (MAINWINDOW)
   ========================================= */
QMainWindow, #centralwidget {
    background-color: #0a0a0a; /* Negro oscuro profundo */
}

/* =========================================
   2. TEXTOS (LABELS)
   ========================================= */
QLabel {
    color: #ffffff; /* Texto blanco */
}

/* =========================================
   3. CAJAS DE TEXTO (USUARIO Y CONTRASEÑA)
   ========================================= */
QLineEdit {
    background-color: rgba(30, 30, 30, 200); /* Gris oscuro semi-transparente */
    border: 2px solid #555555; /* Borde gris apagado por defecto */
    border-radius: 10px; /* Esquinas redondeadas */
    color: #ffffff; /* Letras blancas al escribir */
    padding: 10px;
    font-size: 14px;
}

/* Efecto Neón cuando le das clic a la caja para escribir */
QLineEdit:focus {
    border: 2px solid #ff0000; /* Borde rojo brillante */
    background-color: rgba(50, 20, 20, 200); /* Un ligero tono rojizo en el fondo */
}

/* =========================================
   4. BOTÓN PRINCIPAL (ENTRAR)
   ========================================= */
QPushButton {
    background-color: #ff0000; /* Rojo sólido ZoomFit */
    color: white;
    border-radius: 10px;
    padding: 12px;
    font-size: 16px;
    font-weight: bold;
}

/* Efecto cuando pasas el mouse por encima del botón */
QPushButton:hover {
    background-color: #cc0000; /* Rojo más oscuro para dar efecto de clic */
}

/* =========================================
   5. ESTILO PARA EL CALENDARIO (TABLA)
   ========================================= */
QTableWidget {
    background-color: #0d0d0d;
    gridline-color: #333333; /* Líneas de la tabla discretas */
    border: 1px solid #ff0000;
    color: #ffffff;
}

QHeaderView::section {
    background-color: #1a1a1a;
    color: #ff0000; /* Títulos de días en rojo */
    padding: 5px;
    font-weight: bold;
    border: 1px solid #333333;
}

QTableWidget::item:selected {
    background-color: rgba(255, 0, 0, 100); /* Rojo suave al seleccionar */
    color: white;
}

/* =========================================
   6. ESQUINA SUPERIOR IZQUIERDA DE LA TABLA
   ========================================= */
QTableCornerButton::section {
    background-color: #1a1a1a;
    border: 1px solid #333333;
}

/* =========================================
   7. BARRAS DE DESPLAZAMIENTO (SCROLLBARS)
   ========================================= */
/* Fondo general de la vista de la tabla para áreas sin celdas */
QTableView {
    background-color: #0d0d0d;
}

/* Barra vertical */
QScrollBar:vertical {
    background-color: #121212;
    width: 15px; /* Ancho de la barra */
    margin: 0px 0px 0px 0px;
}

/* El &quot;agarrador&quot; de la barra que subes y bajas */
QScrollBar::handle:vertical {
    background-color: #ff0000; /* Rojo ZoomFit */
    border-radius: 7px;
    min-height: 30px;
}

/* Efecto al pasar el mouse por la barra */
QScrollBar::handle:vertical:hover {
    background-color: #cc0000;
}

/* Ocultar las flechitas feas de arriba y abajo por defecto */
QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
    background: none;
    border: none;
}



/* =========================================
   8. ESTILO PARA COMBOBOX (LISTAS DESPLEGABLES)
   ========================================= */

/* La caja principal del selector */
QComboBox {
    background-color: #121212;
    border: 2px solid #555555; /* Borde gris apagado por defecto */
    border-radius: 10px;
    padding: 8px 15px;
    color: #ffffff;
    font-size: 14px;
}

/* Cuando pasas el mouse o está abierto */
QComboBox:hover, QComboBox:focus {
    border: 2px solid #ff0000; /* Borde rojo neón */
    background-color: #1a1a1a;
}

/* La flecha pequeña (puedes usar una imagen o dejarla básica) */
QComboBox::down-arrow {
	padding-right: 10px;
    width: 12px;
    height: 12px;
}

/* Estilo del botón de la flecha a la derecha */
QComboBox::drop-down {
    subcontrol-origin: padding;
    subcontrol-position: top right;
    width: 35px;
    border-left: 1px solid #333333; /* Línea divisoria sutil */
    border-top-right-radius: 10px;
    border-bottom-right-radius: 10px;
}


/* IMPORTANTE: El menú desplegable (la lista que aparece) */
QComboBox QAbstractItemView {
    background-color: #0d0d0d; /* Fondo casi negro */
    color: #ffffff;
    border: 1px solid #ff0000; /* Borde rojo del menú */
    selection-background-color: #ff0000; /* Fondo rojo al seleccionar */
    selection-color: #ffffff;
    outline: 0px; /* Quita el borde punteado feo de selección */
    border-radius: 5px;
    padding: 5px;
}

/* Cada elemento de la lista */
QComboBox QAbstractItemView::item {
    min-height: 35px; /* Hace los elementos más fáciles de tocar/cliquear */
    padding-left: 10px;
}</string>
  </property>
