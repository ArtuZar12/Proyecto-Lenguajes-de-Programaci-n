  <property name="styleSheet">
   <string notr="true">/* =========================================
   ESTILO DEL DIÁLOGO DE ASISTENCIA
   ========================================= */
QDialog {
    background-color: #0a0a0a;
    border: 2px solid #ff0000; /* Borde neón */
    border-radius: 15px;
}

/* Estilo para el contador digital */
QLCDNumber {
    background-color: #0d0d0d;
    border: 1px solid #333333;
    color: #ff0000; /* Números rojos */
    border-radius: 5px;
    padding: 10px;
}

/* Títulos dentro del diálogo */
QLabel {
    color: white;
    font-size: 18px;
    font-weight: bold;
    text-transform: uppercase;
}

/* Botón de cerrar/aceptar */
QPushButton {
    background-color: #ff0000;
    color: white;
    border-radius: 8px;
    padding: 8px 20px;
    font-weight: bold;
}

QPushButton:hover {
    background-color: #cc0000;
}</string>
